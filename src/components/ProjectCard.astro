---
/**
 * @fileoverview Card de proyecto individual.
 * Componente reutilizable para mostrar un proyecto con imagen, descripción y enlaces.
 * 
 * @component ProjectCard
 */

import type { Project } from "../types/project";
import { StatusConfig, CategoryLabels } from "../types/project";

interface Props {
  project: Project;
  /** Retraso de animación en ms */
  delay?: number;
}

const { project, delay = 0 } = Astro.props;
const { data, slug } = project;

// Tomar las primeras 4 tecnologías para el card
const displayTechs = data.technologies.slice(0, 4);
const hasMoreTechs = data.technologies.length > 4;

const statusConfig = StatusConfig[data.status];
const categoryLabel = CategoryLabels[data.category];
---

<article
  class="project-card group bg-white dark:bg-neutral-900 rounded-2xl overflow-hidden shadow-lg border border-slate-200 dark:border-slate-700 hover:shadow-2xl hover:border-security-blue dark:hover:border-blue-400 transition-all duration-300"
  style={delay > 0 ? `animation-delay: ${delay}ms` : undefined}
>
  <!-- Imagen destacada -->
  {
    data.image ? (
      <div class="relative overflow-hidden h-48 bg-gradient-to-br from-security-blue/10 to-purple-500/10">
        <img
          src={data.image}
          alt={data.title}
          class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
          loading="lazy"
        />
        <!-- Badge de estado superpuesto -->
        <div class="absolute top-3 right-3">
          <span
            class={`px-3 py-1 rounded-full text-xs font-semibold backdrop-blur-sm ${statusConfig.bgClass} ${statusConfig.textClass}`}
          >
            {statusConfig.label}
          </span>
        </div>
      </div>
    ) : (
      <div class="relative h-48 bg-gradient-to-br from-security-blue/20 via-purple-500/20 to-pink-500/20 flex items-center justify-center">
        <svg
          class="w-20 h-20 text-security-blue/30"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
            d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"
          />
        </svg>
        <!-- Badge de estado -->
        <div class="absolute top-3 right-3">
          <span
            class={`px-3 py-1 rounded-full text-xs font-semibold backdrop-blur-sm ${statusConfig.bgClass} ${statusConfig.textClass}`}
          >
            {statusConfig.label}
          </span>
        </div>
      </div>
    )
  }

  <!-- Contenido del card -->
  <div class="p-6">
    <!-- Categoría -->
    <div class="mb-3">
      <span
        class="inline-block px-3 py-1 bg-security-blue/10 dark:bg-security-blue/20 text-security-blue dark:text-blue-300 text-xs font-semibold rounded-full"
      >
        {categoryLabel}
      </span>
    </div>

    <!-- Título -->
    <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-2 group-hover:text-security-blue dark:group-hover:text-blue-400 transition-colors">
      <a href={`/proyectos/${slug}`} class="hover:underline">
        {data.title}
      </a>
    </h3>

    <!-- Descripción breve -->
    <p class="text-slate-600 dark:text-gray-300 text-sm mb-4 leading-relaxed line-clamp-3">
      {data.description}
    </p>

    <!-- Tecnologías -->
    <div class="flex flex-wrap gap-2 mb-4">
      {
        displayTechs.map((tech) => (
          <span class="px-2 py-1 bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 text-xs rounded-md">
            {tech}
          </span>
        ))
      }
      {
        hasMoreTechs && (
          <span class="px-2 py-1 bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400 text-xs rounded-md">
            +{data.technologies.length - 4}
          </span>
        )
      }
    </div>

    <!-- Enlaces de acción -->
    <div class="flex gap-3 pt-4 border-t border-slate-200 dark:border-slate-700">
      {
        data.demoUrl && (
          <a
            href={data.demoUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 px-4 py-2 bg-security-blue hover:bg-security-blue-light text-white rounded-lg text-sm font-medium transition-colors"
          >
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
              />
            </svg>
            Ver Demo
          </a>
        )
      }
      <a
        href={data.repoUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 px-4 py-2 bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-300 rounded-lg text-sm font-medium transition-colors"
      >
        <svg
          class="w-4 h-4"
          fill="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            fill-rule="evenodd"
            d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
            clip-rule="evenodd"
          />
        </svg>
        Código
      </a>
    </div>
  </div>
</article>

<style>
  .project-card {
    animation: fadeInUp 0.5s ease-out backwards;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
