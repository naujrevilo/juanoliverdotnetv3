---
import Layout from "../../layouts/Layout.astro";
import ProjectsList from "../../components/ProjectsList.svelte";
import { getCollection } from "astro:content";

export const prerender = true;

const projects = await getCollection("projects");
projects.sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);

const totalProjects = projects.length;
const activeProjects = projects.filter(
  (p) => p.data.status === "público",
).length;
const featuredProjects = projects.filter((p) => p.data.featured).length;

// Estadísticas de categorías
const categorySet = new Set<string>();
for (const project of projects) {
  categorySet.add(project.data.category);
}
---

<Layout
  title="Proyectos | Juan Oliver"
  description="Portafolio de aplicaciones y proyectos de código abierto desarrollados por Juan Oliver. Herramientas de escritorio, sitios web, APIs y utilidades."
  fullWidth={true}
>
  <!-- Hero Section -->
  <section
    class="relative overflow-hidden bg-slate-50 dark:bg-slate-950 text-slate-900 dark:text-white border-b border-slate-200 dark:border-slate-800 transition-colors duration-300"
  >
    <!-- Background decorations -->
    <div
      class="absolute inset-0 pattern-grid-lg text-slate-400 dark:text-white/10 opacity-30"
    >
    </div>
    <div
      class="absolute -top-32 -right-24 w-72 h-72 bg-security-blue/20 rounded-full blur-3xl"
    >
    </div>
    <div
      class="absolute -bottom-40 -left-10 w-80 h-80 bg-security-green/10 rounded-full blur-3xl"
    >
    </div>

    <div class="container max-w-6xl mx-auto px-4 py-16 lg:py-20 relative z-10">
      <!-- Badge -->
      <div class="mb-6">
        <span
          class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-security-blue/10 dark:bg-security-blue/20 border border-security-blue/30 text-xs font-semibold uppercase tracking-[0.2em] text-security-blue dark:text-security-blue-light backdrop-blur-sm"
        >
          <svg
            class="w-4 h-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
          </svg>
          Mis Proyectos
        </span>
      </div>

      <!-- Title -->
      <h1
        class="text-4xl md:text-5xl lg:text-6xl font-black tracking-tight mb-5 text-security-blue dark:text-security-blue-light"
      >
        Aplicaciones que construyo
      </h1>

      <!-- Description -->
      <p
        class="max-w-3xl text-slate-600 dark:text-slate-300 text-lg md:text-xl leading-relaxed mb-8"
      >
        Un vistazo a las herramientas, sitios web y utilidades que desarrollo en
        mi tiempo libre. Desde editores de escritorio hasta portales de
        noticias, cada proyecto resuelve un problema real o explora una
        tecnología interesante.
      </p>

      <!-- Stats -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
        <div
          class="px-4 py-3 rounded-lg bg-white/50 dark:bg-white/5 border border-slate-200 dark:border-white/10 backdrop-blur-sm"
        >
          <p
            class="text-2xl font-bold text-security-blue dark:text-security-blue-light"
          >
            {totalProjects}
          </p>
          <p
            class="text-xs text-slate-600 dark:text-slate-400 uppercase tracking-wider"
          >
            Proyectos
          </p>
        </div>
        <div
          class="px-4 py-3 rounded-lg bg-white/50 dark:bg-white/5 border border-slate-200 dark:border-white/10 backdrop-blur-sm"
        >
          <p
            class="text-2xl font-bold text-security-green dark:text-security-green-light"
          >
            {activeProjects}
          </p>
          <p
            class="text-xs text-slate-600 dark:text-slate-400 uppercase tracking-wider"
          >
            Públicos
          </p>
        </div>
        <div
          class="px-4 py-3 rounded-lg bg-white/50 dark:bg-white/5 border border-slate-200 dark:border-white/10 backdrop-blur-sm"
        >
          <p
            class="text-2xl font-bold text-security-purple dark:text-security-purple-light"
          >
            {featuredProjects}
          </p>
          <p
            class="text-xs text-slate-600 dark:text-slate-400 uppercase tracking-wider"
          >
            Destacados
          </p>
        </div>
        <div
          class="px-4 py-3 rounded-lg bg-white/50 dark:bg-white/5 border border-slate-200 dark:border-white/10 backdrop-blur-sm"
        >
          <p
            class="text-2xl font-bold text-security-orange dark:text-security-orange-light"
          >
            {categorySet.size}
          </p>
          <p
            class="text-xs text-slate-600 dark:text-slate-400 uppercase tracking-wider"
          >
            Categorías
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Projects List Section -->
  <section
    class="py-16 lg:py-24 bg-white dark:bg-slate-900 transition-colors duration-300"
  >
    <div class="container max-w-7xl mx-auto px-4">
      <ProjectsList
        client:load
        projects={projects.map((p) => ({
          slug: p.slug,
          data: {
            ...p.data,
            publishDate: p.data.publishDate.toISOString(),
          },
        }))}
      />
    </div>
  </section>

  <!-- CTA Section -->
  <section
    class="py-16 lg:py-20 bg-gradient-to-br from-security-blue to-security-blue-dark text-white"
  >
    <div class="container max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">
        ¿Tienes un proyecto en mente?
      </h2>
      <p class="text-lg md:text-xl text-blue-100 mb-8 max-w-2xl mx-auto">
        Si te gustaría colaborar en alguno de estos proyectos o necesitas ayuda
        con uno propio, no dudes en contactarme.
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a
          href="/contacto"
          class="inline-flex items-center gap-2 px-8 py-4 bg-white text-security-blue rounded-lg font-semibold hover:bg-blue-50 transition-all duration-200 shadow-lg hover:shadow-xl"
        >
          <svg
            class="w-5 h-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
            ></path>
          </svg>
          Contactar
        </a>
        <a
          href="https://github.com/naujrevilo"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-8 py-4 bg-security-blue-dark/50 backdrop-blur-sm border-2 border-white/30 text-white rounded-lg font-semibold hover:bg-security-blue-dark/70 transition-all duration-200"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path
              fill-rule="evenodd"
              clip-rule="evenodd"
              d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.167 22 16.418 22 12c0-5.523-4.477-10-10-10z"
            ></path>
          </svg>
          Ver en GitHub
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .pattern-grid-lg {
    background-image:
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 49px,
        currentColor 49px,
        currentColor 50px
      ),
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 49px,
        currentColor 49px,
        currentColor 50px
      );
  }
</style>
